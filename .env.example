# Copy to `.env` and fill in. `.env` is gitignored so your key never lands in git.
#
# LedgerLens is KEY-OPTIONAL:
#   * With GOOGLE_API_KEY set  -> live Gemini-backed ADK multi-agent system.
#   * Without it               -> deterministic mock orchestrator (same routing,
#                                 same tools, no network). Tests always run here.

# Get a free key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Gemini model used by the ADK agents when a key is present.
LEDGERLENS_MODEL=gemini-2.0-flash

# ---------------------------------------------------------------------------
# Local / self-hosted LLM (OpenAI-compatible, e.g. a vLLM server).
# If LEDGERLENS_LLM_BASE_URL is set it TAKES PRECEDENCE over Gemini, and no
# cloud key is needed. The base URL must include the /v1 suffix.
# For these, also set LEDGERLENS_MODEL to the served model name (not a Gemini id).
# ---------------------------------------------------------------------------
# LEDGERLENS_LLM_BASE_URL=https://your-host:12000/v1
# LEDGERLENS_LLM_API_KEY=test
# LEDGERLENS_MODEL=LocalLLM

# Optional: point at a different transactions CSV.
# LEDGERLENS_DATA_PATH=./data/transactions.csv
